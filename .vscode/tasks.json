{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "nwa: add license headers (include/**/*.h)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/add-licenses-include-h.sh",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Generate HDF5 Config for PV",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/generate-hdf5-config.sh",
      "args": [
        "${input:pvName}"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}