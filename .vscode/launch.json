{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Launch Tests",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "initCommands": []
        },
        {
            "name": "(lldb) Launch Tests - Specific Test",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [
                "--gtest_filter=${input:testFilter}"
            ],
            "cwd": "${workspaceFolder}",
            "initCommands": [
                "settings set target.disable-aslr false"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "(gdb) Launch Tests",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
        },
        {
            "name": "(lldb) Launch HDF5 Driver (PV as Parameter)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver",
            "args": [
                "--config",
                "${workspaceFolder}/.vscode/config-hdf5-pv-${input:pvName}.yaml",
                "--log-level",
                "${input:logLevel}"
            ],
            "preLaunchTask": "Generate HDF5 Config for PV",
            "cwd": "${workspaceFolder}",
            "disableASLR": false,
            "console": "integratedTerminal",
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
        },
        {
            "name": "(lldb) Launch mock_sioc_server",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mock_sioc_server",
            "args": [],
            "cwd": "${workspaceFolder}",
            "disableASLR": false,
            "console": "integratedTerminal",
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
        },
        {
            "name": "(lldb) Launch Main",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver",
            "args": [
                "--config",
                "${input:configPath}",
                "--log-level",
                "${input:logLevel}"
            ],
            "cwd": "${workspaceFolder}",
            "disableASLR": false,
            "console": "integratedTerminal",
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
        }
    ],
    "inputs": [
        {
            "id": "testFilter",
            "type": "promptString",
            "description": "Enter GTest filter (e.g., pvxs_mldp_driver.counter)",
            "default": "*"
        },
        {
            "id": "pvName",
            "type": "promptString",
            "description": "PV name to use (e.g., TEST:VOLTAGE)",
            "default": "TEST:VOLTAGE"
        },
        {
            "id": "configPath",
            "type": "promptString",
            "description": "Config file path for --config",
            "default": "${workspaceFolder}/config.yaml"
        },
        {
            "id": "logLevel",
            "type": "promptString",
            "description": "Log level for --log-level (trace, debug, info, warn, error, critical, off)",
            "default": "info",
            "options": ["trace", "debug", "info", "warn", "error", "critical", "off"]
        }
    ]
}