{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Launch Tests",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [],
            // "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "disableASLR": false,
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
            
            // "environment": [],
            // "externalConsole": false,
            // "MIMode": "lldb",
            // "setupCommands": [
            //     {
            //         "description": "Enable pretty-printing for lldb",
            //         "text": "-enable-pretty-printing",
            //         "ignoreFailures": true
            //     }
            // ]
        },
        {
            "name": "(lldb) Launch Tests - Specific Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [
                "--gtest_filter=${input:testFilter}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for lldb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(lldb) Launch Main",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/mldp_pvxs_driver",
            "args": [
                "${workspaceFolder}/config.yml"
            ],
            // "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "disableASLR": false,
            "initCommands": [
                "settings set target.disable-aslr false"
            ]
            // "environment": [],
            // "externalConsole": false,
            // "setupCommands": [
            //     {
            //         "description": "Keep ASLR enabled (workaround for restricted personality())",
            //         "text": "settings set target.disable-aslr false"
            //     }
            // ]
        }
    ],
    "inputs": [
        {
            "id": "testFilter",
            "type": "promptString",
            "description": "Enter GTest filter (e.g., pvxs_mldp_driver.counter)",
            "default": "*"
        }
    ]
}
